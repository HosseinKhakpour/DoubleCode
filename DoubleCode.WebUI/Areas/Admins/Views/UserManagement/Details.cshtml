@model UserManagementCreateOrEditViewModel
@{
    ViewData["Title"] = "جزییات کاربر ";
    Layout = "~/Areas/Admins/Views/Shared/_AdminLayout.cshtml";
}
<!-- Start right Content here -->
<!-- ============================================================== -->
<div class="content-page">
    <!-- Start content -->
    <div class="content">
        <div class="container">
            <div class="row">
                <div class="col-sm-8">
                    <div class="bg-picture card-box">
                        <div class="profile-info-name">
                           <img src="~/img/users/avatar-1.jpg" 
                                 class="img-thumbnail" alt="profile-image">

                            <div class="profile-info-detail">
                                <h4 class="m-t-0 m-b-4">@Html.DisplayFor(model => model.UserName)</h4>
                                <div class="text-left m-l-20">
                                    <p class="text-muted font-13"><strong>نام کاربری  :</strong> <span class="m-l-15">@Model.UserName</span></p>

                                    <p class="text-muted font-13"><strong>موبایل :</strong><span class="m-l-15">+98911234567</span></p>

                                    <p class="text-muted font-13"><strong>ایمیل :</strong> <span class="m-l-15">@Model.Email</span></p>

                                    <p class="text-muted font-13"><strong>تاریخ ثبت نام :</strong> <span class="m-l-15">@Model.CreateDate.ToPeString("dddd, dd MMMM,yyyy")</span></p>
                                </div>
                                <div class="button-list m-t-20">
                                    <button asp-area="Admins" asp-controller="UserManagement" asp-action="Edit" asp-route-id="@Model.Id" type="button" class="btn btn-warning waves-effect waves-light">
                                        <i class="fa fa-pencil"></i>
                                    </button>
                                    <button asp-area="Admins" asp-controller="UserManagement" asp-action="Delete" asp-route-id="@Model.Id" type="button" class="btn btn-danger waves-effect waves-light">
                                        <i class="zmdi zmdi-delete"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="clearfix"></div>
                        </div>
