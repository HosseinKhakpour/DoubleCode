@model UserManagementCreateOrEditViewModel
@{
    ViewData["Title"] = "حذف کاربر";
    Layout = "~/Areas/Admins/Views/Shared/_AdminLayout.cshtml";
}
<title>@ViewData["Title"]</title>
<div class="content-page">
    <!-- Start content -->
    <div class="content">
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <div class="text-center card-box">
                        <div>
                            <img src="~/img/users/avatar-1.jpg" class="img-circle thumb-xl img-thumbnail m-b-10" alt="profile-image">
                            <p class="text-muted font-13 m-b-30">
                                آیا از حذف مطلب « @Model.UserName » مطمئن هستید ؟
                            </p>
                            <div class="text-left">
                                <p class="text-muted font-13"><strong>نام کاربری  :</strong> <span class="m-l-15">@Model.UserName</span></p>

                                <p class="text-muted font-13"><strong>موبایل :</strong><span class="m-l-15">+98911234567</span></p>

                                <p class="text-muted font-13"><strong>ایمیل :</strong> <span class="m-l-15">@Model.Email</span></p>

                                <p class="text-muted font-13"><strong>تاریخ ثبت نام :</strong> <span class="m-l-15">@Model.CreateDate</span></p>
                            </div>
                            <form asp-action="Delete">
                                <br />
                                <input type="hidden" asp-for="Id" />
                                <a asp-action="Delete" type="button" class="btn btn-danger btn-rounded waves-effect waves-light">حذف</a>
                                <a asp-action="Index" type="button" class="btn btn-success btn-rounded waves-effect waves-light">برگشت</a>
                            </form>
                        </div>
                    </div>
                </div> <!-- end col -->
            </div>
        </div>
    </div>
</div>