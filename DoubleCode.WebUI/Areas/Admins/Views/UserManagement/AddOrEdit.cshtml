@model UserManagementCreateOrEditViewModel
@{
    ViewData["Title"] = (Model.Id == null ? "افزودن" : $" ویرایش");
}
<title>@ViewData["Title"]</title>
<div class="content-page">
    <!-- Start content -->
    <div class="content">
        <div class="container">
            <div class="row">
                <div class="col-sm-12">
                    <div class="card-box">
                        <div class="row">
                            <div class="col-md-12">
                                <h4 class="m-t-0 header-title"><b>@(Model.Id == null ? "افزودن" : $" ویرایش")</b></h4>
                                <form asp-action="@(Model.Id == null ? "Add" : "Edit")" role="form">
                                    <div asp-validation-summary="ModelOnly" class="text-danger" ></div>
                                    <div class="form-group col-lg-6">
                                        <label asp-for="UserName" class="control-label"></label>
                                        <input asp-for="UserName" class="form-control" />
                                        <span asp-validation-for="UserName" class="text-danger" placeholder="نام کاربری خود  را وارد کنید"></span>
                                    </div>
                                    <div class="form-group col-lg-6">
                                        <label asp-for="Email" class="control-label"></label>
                                        <input asp-for="Email" class="form-control" />
                                        <span asp-validation-for="Email" class="text-danger" placeholder="ایمیل خود  را وارد کنید"></span>
                                    </div>
                                    @if (Model.Id == null)
                                    {
                                        <div class="form-group col-lg-12">
                                            <label asp-for="Password" class="control-label"></label>
                                            <input type="password" asp-for="Password" class="form-control" />
                                            <span asp-validation-for="Password" class="text-danger"></span>
                                        </div>
                                    }
                                    @if (Model.Id != null)
                                    {
                                        <input asp-for="CreateDate" type="hidden" />
                                        <input type="hidden" asp-for="Id" />
                                        <input type="hidden" asp-for="Password" />
                                        <div class="form-group col-lg-offset-11">
                                            <input type="submit" value="Edit" class="btn btn-success" />
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="form-group col-lg-offset-11">
                                            <input type="submit" value="Add" class="btn btn-success" />
                                        </div>
                                    }
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>